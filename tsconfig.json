{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [],
    "outDir": "./src"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.test.ts"]
}
